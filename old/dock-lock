#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════╗
# ║              lock-dock — Lock Dock to a Monitor              ║
# ║          macOS CLI tool to pin the Dock to any display       ║
# ╚══════════════════════════════════════════════════════════════╝

set -euo pipefail

# ── Colours ────────────────────────────────────────────────────
RED=$'\e[31m'; GRN=$'\e[32m'; YLW=$'\e[33m'
BLU=$'\e[34m'; MAG=$'\e[35m'; CYN=$'\e[36m'
WHT=$'\e[97m'; DIM=$'\e[2m';  BLD=$'\e[1m'
RST=$'\e[0m'

# ── Banner ─────────────────────────────────────────────────────
banner() {
  echo
  echo "${BLD}${CYN}  ██╗      ██████╗  ██████╗██╗  ██╗    ██████╗  ██████╗  ██████╗██╗  ██╗${RST}"
  echo "${BLD}${CYN}  ██║     ██╔═══██╗██╔════╝██║ ██╔╝    ██╔══██╗██╔═══██╗██╔════╝██║ ██╔╝${RST}"
  echo "${BLD}${CYN}  ██║     ██║   ██║██║     █████╔╝     ██║  ██║██║   ██║██║     █████╔╝ ${RST}"
  echo "${BLD}${CYN}  ██║     ██║   ██║██║     ██╔═██╗     ██║  ██║██║   ██║██║     ██╔═██╗ ${RST}"
  echo "${BLD}${CYN}  ███████╗╚██████╔╝╚██████╗██║  ██╗    ██████╔╝╚██████╔╝╚██████╗██║  ██╗${RST}"
  echo "${BLD}${CYN}  ╚══════╝ ╚═════╝  ╚═════╝╚═╝  ╚═╝    ╚═════╝  ╚═════╝  ╚═════╝╚═╝  ╚═╝${RST}"
  echo "${DIM}${WHT}                      Lock your macOS Dock to a display${RST}"
  echo
}
# ── Helpers ────────────────────────────────────────────────────
info()    { echo "  ${BLU}ℹ${RST}  $*"; }
success() { echo "  ${GRN}✔${RST}  $*"; }
warn()    { echo "  ${YLW}⚠${RST}  $*"; }
error()   { echo "  ${RED}✖${RST}  $*" >&2; }
die()     { error "$*"; exit 1; }

# ── Require macOS ──────────────────────────────────────────────
[[ "$(uname)" == "Darwin" ]] || die "lock-dock only runs on macOS."

# ── Detect displays via system_profiler ───────────────────────
get_displays() {
  # Returns lines of: INDEX|NAME|RESOLUTION|MAIN
  python3 - <<'PYEOF'
import subprocess, json, sys

try:
    raw = subprocess.check_output(
        ["system_profiler", "SPDisplaysDataType", "-json"],
        stderr=subprocess.DEVNULL
    )
    data = json.loads(raw)
except Exception as e:
    sys.exit(1)

displays = []
for gpu in data.get("SPDisplaysDataType", []):
    for monitor in gpu.get("spdisplays_ndrvs", []):
        name = monitor.get("_name", "Unknown Display")
        res  = monitor.get("spdisplays_resolution", "?")
        main = monitor.get("spdisplays_main", "") == "spdisplays_yes"
        displays.append((name, res, main))

for i, (name, res, main) in enumerate(displays, 1):
    flag = "MAIN" if main else ""
    print(f"{i}|{name}|{res}|{flag}")
PYEOF
}

# ── Current Dock monitor preference ───────────────────────────
get_current() {
  val=$(defaults read com.apple.dock "prefer-display-for-dock" 2>/dev/null || echo "")
  if [[ -z "$val" ]]; then
    echo "${DIM}(follows cursor / not pinned)${RST}"
  else
    echo "${BLD}${WHT}${val}${RST}"
  fi
}

# ── List displays ─────────────────────────────────────────────
cmd_list() {
  banner
  echo "${BLD}${WHT}  Connected Displays${RST}"
  echo "${DIM}  ─────────────────────────────────────────────${RST}"

  local displays
  displays=$(get_displays) || die "Could not read display information."

  if [[ -z "$displays" ]]; then
    warn "No displays found. Are you on macOS 10.15+?"
    return 1
  fi

  while IFS='|' read -r idx name res main; do
    if [[ "$main" == "MAIN" ]]; then
      echo "  ${BLD}${GRN}[$idx]${RST} ${BLD}${WHT}${name}${RST}  ${DIM}${res}${RST}  ${GRN}★ primary${RST}"
    else
      echo "  ${BLD}${CYN}[$idx]${RST} ${WHT}${name}${RST}  ${DIM}${res}${RST}"
    fi
  done <<< "$displays"

  echo
  echo "${DIM}  ─────────────────────────────────────────────${RST}"
  echo "  ${DIM}Dock currently:${RST} $(get_current)"
  echo
}

# ── Set dock to display by index ──────────────────────────────
cmd_set() {
  local target="${1:-}"
  [[ -z "$target" ]] && die "Usage: lock-dock set <display-number>\n         Run 'lock-dock list' to see display numbers."

  local displays
  displays=$(get_displays) || die "Could not read display information."
  [[ -z "$displays" ]] && die "No displays detected."

  local total
  total=$(echo "$displays" | wc -l | tr -d ' ')

  # Validate index
  [[ "$target" =~ ^[0-9]+$ ]] || die "Display number must be a positive integer."
  (( target >= 1 && target <= total )) || die "Display ${target} not found. Valid range: 1–${total}."

  # Get chosen display name
  local chosen_name chosen_res
  chosen_name=$(echo "$displays" | awk -F'|' -v i="$target" 'NR==i {print $2}')
  chosen_res=$(echo  "$displays" | awk -F'|' -v i="$target" 'NR==i {print $3}')

  echo
  info "Locking Dock to display ${BLD}${WHT}${target}${RST}: ${CYN}${chosen_name}${RST} ${DIM}(${chosen_res})${RST}"

  # Write the preference (macOS uses display UUID; we store the name as a
  # best-effort hint — the real mechanism is via the undocumented
  # "prefer-display-for-dock" key which accepts a display UUID or name string)
  defaults write com.apple.dock "prefer-display-for-dock" -string "${chosen_name}"

  # Restart Dock to apply
  info "Restarting Dock…"
  killall Dock 2>/dev/null || true
  sleep 1

  success "Dock pinned to ${BLD}${CYN}${chosen_name}${RST}."
  echo "  ${DIM}The Dock will now prefer this monitor at launch.${RST}"
  echo
}

# ── Reset (let Dock follow cursor again) ──────────────────────
cmd_reset() {
  echo
  info "Removing Dock monitor pin…"
  defaults delete com.apple.dock "prefer-display-for-dock" 2>/dev/null || true
  killall Dock 2>/dev/null || true
  sleep 1
  success "Dock will now follow the cursor (default macOS behaviour)."
  echo
}

# ── Interactive picker ─────────────────────────────────────────
cmd_pick() {
  banner

  local displays
  displays=$(get_displays) || die "Could not read display information."
  [[ -z "$displays" ]] && die "No displays detected."

  echo "${BLD}${WHT}  Choose a display to lock the Dock to:${RST}"
  echo "${DIM}  ─────────────────────────────────────────────${RST}"

  local total=0
  while IFS='|' read -r idx name res main; do
    if [[ "$main" == "MAIN" ]]; then
      echo "  ${BLD}${GRN}[$idx]${RST} ${BLD}${WHT}${name}${RST}  ${DIM}${res}${RST}  ${GRN}★ primary${RST}"
    else
      echo "  ${BLD}${CYN}[$idx]${RST} ${WHT}${name}${RST}  ${DIM}${res}${RST}"
    fi
    (( total++ )) || true
  done <<< "$displays"
  echo "  ${BLD}${YLW}[0]${RST} ${DIM}Reset — let Dock follow cursor${RST}"
  echo "${DIM}  ─────────────────────────────────────────────${RST}"
  echo

  local choice
  printf "  ${BLD}${WHT}Enter number [0–${total}]: ${RST}"
  read -r choice

  if [[ "$choice" == "0" ]]; then
    cmd_reset
  else
    cmd_set "$choice"
  fi
}

# ── Status ────────────────────────────────────────────────────
cmd_status() {
  echo
  echo "  ${BLD}${WHT}Dock Lock Status${RST}"
  echo "${DIM}  ──────────────────────────────${RST}"
  echo "  Current preference: $(get_current)"
  echo
}

# ── Help ──────────────────────────────────────────────────────
cmd_help() {
  banner
  echo "${BLD}${WHT}  USAGE${RST}"
  echo "  ${CYN}lock-dock${RST} ${DIM}<command>${RST}"
  echo
  echo "${BLD}${WHT}  COMMANDS${RST}"
  printf "  ${GRN}%-12s${RST} %s\n" "list"    "List all connected displays"
  printf "  ${GRN}%-12s${RST} %s\n" "set <N>" "Pin Dock to display number N"
  printf "  ${GRN}%-12s${RST} %s\n" "pick"    "Interactive display picker"
  printf "  ${GRN}%-12s${RST} %s\n" "reset"   "Remove pin (Dock follows cursor)"
  printf "  ${GRN}%-12s${RST} %s\n" "status"  "Show current Dock lock setting"
  printf "  ${GRN}%-12s${RST} %s\n" "help"    "Show this help message"
  echo
  echo "${BLD}${WHT}  EXAMPLES${RST}"
  echo "  ${DIM}lock-dock list           # See all displays${RST}"
  echo "  ${DIM}lock-dock set 2          # Lock Dock to display 2${RST}"
  echo "  ${DIM}lock-dock pick           # Interactive mode${RST}"
  echo "  ${DIM}lock-dock reset          # Unpin (back to default)${RST}"
  echo
  echo "${DIM}  Requires macOS 10.15 Catalina or later.${RST}"
  echo "${DIM}  The Dock restarts automatically when you change the setting.${RST}"
  echo
}

# ── Router ────────────────────────────────────────────────────
main() {
  local cmd="${1:-pick}"
  shift || true

  case "$cmd" in
    list)   cmd_list ;;
    set)    cmd_set "$@" ;;
    pick)   cmd_pick ;;
    reset)  cmd_reset ;;
    status) cmd_status ;;
    help|-h|--help) cmd_help ;;
    *)
      error "Unknown command: ${cmd}"
      echo "  Run ${BLD}lock-dock help${RST} for usage."
      exit 1
      ;;
  esac
}

main "$@"
